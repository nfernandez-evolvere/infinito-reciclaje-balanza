# =============================================================================
#  Dominios del nginx EDGE — ÚNICA fuente de verdad de las URLs de prod y staging.
#
#  Copiar a `.env.edge` en el host (y localmente si se prueba el edge) y completar.
#  NO se commitea: `.env.*` está en .gitignore, y al no ser un archivo trackeado
#  sobrevive al `git reset --hard` del deploy (igual que .env.prod / .env.staging).
#
#  El edge usa estos valores como `server_name` de cada bloque. Para cambiar un
#  dominio: editar `.env.edge` y RECREAR el edge (el template solo se renderiza al
#  iniciar el contenedor; un `nginx -s reload` NO re-procesa el template):
#
#     docker compose -p app-edge -f compose.edge.yaml up -d
# =============================================================================

# Dominio público de PRODUCCIÓN  (server_name del bloque prod)
APP_DOMAIN=balanza.tudominio.com

# Dominio público de STAGING     (server_name del bloque staging)
STAGE_DOMAIN=staging.balanza.tudominio.com
