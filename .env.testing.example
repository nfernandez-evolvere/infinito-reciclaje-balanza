APP_NAME="Infinito Reciclaje"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# --- Base de TEST dedicada en SQL Server (mismo motor que producción) ---
# Crear una database EXCLUSIVA para tests (no la compartida entre proyectos).
# El nombre DEBE contener "test": TestCase aborta si no, para que RefreshDatabase
# (migrate:fresh) nunca pueda correr contra la base compartida.
DB_CONNECTION=sqlsrv
DB_HOST=localhost\SQLEXPRESS
DB_PORT=
DB_DATABASE=infinito_balanza_testing
DB_USERNAME=usuario_testing
DB_PASSWORD=
DB_SCHEMA=dbo
DB_TABLE_PREFIX=test_

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
