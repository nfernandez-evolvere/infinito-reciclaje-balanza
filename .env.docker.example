# =============================================================================
#  Plantilla de entorno para PRODUCCIÓN en Docker.
#  Copiar a `.env.prod` en el host y completar los valores reales.
#  NO commitear .env.prod — contiene secretos.
# =============================================================================

APP_NAME="Infinito Reciclaje"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                       # generar: php artisan key:generate --show
APP_URL=https://balanza.tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

# --- Base de datos: SQL Server EXTERNO compartido ----------------------------
# El contenedor NUNCA corre la DB; se conecta al SQL Server del proyecto.
DB_CONNECTION=sqlsrv
DB_HOST=                       # IP/host del SQL Server (puerto estático)
DB_PORT=1433
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SCHEMA=dbo
DB_TABLE_PREFIX=prod_
# Si el server usa certificado self-signed, relajar el cifrado:
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=false

# --- Drivers (mismos que dev: todo en la base) -------------------------------
QUEUE_CONNECTION=database
SESSION_DRIVER=database
CACHE_STORE=database
SESSION_LIFETIME=120

# --- Logs --------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Mail -----------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Infinito Reciclaje"

# --- Blue-green (no tocar salvo que cambien puertos/imagen) ------------------
# TAG lo inyecta docker/deploy.sh con el SHA del commit desplegado.
